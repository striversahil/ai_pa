        "5": {
          "id": "5",
          "name": "javascript-code",
          "data": {
            "code": "const selection = window.getSelection().toString().trim();\nif (selection) {\n  automaSetVariable('scrapedContent', selection);\n  automaNextBlock();\n} else {\n  const aiHeader = Array.from(document.querySelectorAll('h2, span, div')).find(el => el.textContent.includes('AI Overview'));\n  let content = '';\n  if (aiHeader) {\n    let parent = aiHeader.parentElement;\n    for (let i = 0; i < 5; i++) {\n      if (parent && (parent.tagName === 'G-CARD' || parent.classList.contains('dn1Noc') || parent.offsetHeight > 100)) {\n        content = parent.innerText;\n        break;\n      }\n      parent = parent?.parentElement;\n    }\n  }\n  if (!content) {\n    content = document.querySelector('#rso')?.innerText || document.body.innerText;\n  }\n  automaSetVariable('scrapedContent', content);\n  automaNextBlock();\n}",
            "runBg": false
          },
